{
  "manifest_version": 3,
  "name": "Orderly Extension",
  "version": "1.0.0",
  "description": "Chrome extension scaffold for Orderly.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
